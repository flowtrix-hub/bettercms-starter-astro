---
import Base from "../layouts/Base.astro";
import BcmsBlocks from "@bettercms-ai/astro/components/BcmsBlocks.astro";
import { getPage, getForms } from "../lib/content";

const page = getPage("home");
const { items: forms, turnstileSiteKey } = getForms();
---

<Base title={page?.metaTitle ?? "Acme — Marketing Starter"} description={page?.metaDescription}>
  <main class="page-body">
    {page ? (
      <BcmsBlocks blocks={page.blocks} forms={forms} turnstileSiteKey={turnstileSiteKey} />
    ) : (
      <p>This page hasn’t been published yet.</p>
    )}
  </main>
</Base>
