---
/** Shared page shell: <head> meta + nav + footer. Marketing pages render their CMS block tree
 *  into the slot; blog/case routes render their own markup. Nav/footer are site chrome, not CMS
 *  content (mirrors the Next starter). */
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string | null;
}
const { title = "Acme", description } = Astro.props;
const NAV = [
  { label: "Home", href: "/" },
  { label: "Blog", href: "/blog" },
  { label: "Case Studies", href: "/case-studies" },
  { label: "About", href: "/about" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <nav class="site-nav">
      <a class="brand" href="/">Acme</a>
      <div class="links">
        {NAV.map((l) => <a href={l.href}>{l.label}</a>)}
        <a class="bcms-btn bcms-btn-primary" href="/contact">Contact</a>
      </div>
    </nav>
    <slot />
    <footer class="site-footer">
      <p>© Acme, Inc. Built with BetterCMS.</p>
    </footer>
  </body>
</html>
