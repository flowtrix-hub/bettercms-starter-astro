# Security headers for headless deploys (Cloudflare Pages / Netlify read this file;
# it is copied to the build root). BetterCMS hosting sets these for you at the edge —
# this starter config is for when you deploy to your OWN host. Tune the CSP per site.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  # Content-Security-Policy needs per-site tuning. Start in report-only so it never
  # breaks the page, watch the browser console, then switch to Content-Security-Policy:
  # Content-Security-Policy-Report-Only: default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline';
