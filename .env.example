# BetterCMS delivery reads — a content:read key is enough for the site.
# On BetterCMS hosting these are injected automatically when you create the site
# from the Marketing Starter template; set them here only for local development.
PUBLIC_BCMS_API_URL=https://api.bettercms.ai
PUBLIC_BCMS_WORKSPACE=your-workspace-slug
BCMS_API_KEY=bcms_xxx
